{
  "name": "web-mcp-sdk",
  "version": "0.1.0",
  "type": "module",
  "description": "Browser SDK that exposes window.agent_tool.registerTool and talks to web-mcp-bridge over WebSocket.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "web-mcp-shared": "workspace:*",
    "zod-to-json-schema": "^3.23.0"
  },
  "peerDependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "zod": "^3.23.8",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}