{
  "name": "web-page-mcp-shared",
  "version": "1.0.2",
  "type": "module",
  "description": "Shared protocol types, constants and zod schemas used by web-page-mcp-bridge and web-page-mcp-sdk.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public",
    "replaceWorkspaceProtocol": true
  }
}