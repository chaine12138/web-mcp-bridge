{
  "name": "@web-mcp/bridge",
  "version": "0.1.0",
  "type": "module",
  "description": "Local MCP server that forwards tool calls to in-browser host apps over WebSocket.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "web-mcp-bridge": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@web-mcp/shared": "workspace:*",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ws": "^8.5.12",
    "@types/node": "^20.14.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "publishConfig": {
    "access": "public"
  }
}